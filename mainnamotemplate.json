{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",

  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "Central India"
    },
    "vnetName": {
      "type": "string",
      "defaultValue": "vnet1"
    },
    "subnet1Prefix": {
      "type": "string"
    },
    "subnet2Prefix": {
      "type": "string"
    },
    "vm1Name": {
      "type": "string"
    },
    "vm2Name": {
      "type": "string"
    },
    "adminUsername": {
      "type": "string"
    },
    "adminPassword": {
      "type": "secureString"
    },
    "principalId": {
      "type": "string"
    },
    "nestedTemplateUrl": {
      "type": "string"
    }
  },

  "resources": [

    // NSG
    {
      "type": "Microsoft.Network/networkSecurityGroups",
      "apiVersion": "2021-05-01",
      "name": "nsg1",
      "location": "[parameters('location')]",
      "properties": {
        "securityRules": [
          {
            "name": "Allow-SSH",
            "properties": {
              "priority": 100,
              "access": "Allow",
              "direction": "Inbound",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "22",
              "sourceAddressPrefix": "*",
              "destinationAddressPrefix": "*"
            }
          },
          {
              "name": "Allow-RDP",
              "properties": {
                "priority": 90,
                "access": "Allow",
                "direction": "Inbound",
                "protocol": "Tcp",
                "sourcePortRange": "*",
                "destinationPortRange": "3389",
                "sourceAddressPrefix": "*",
                "destinationAddressPrefix": "*"
              }
            },
          {
            "name": "Allow-HTTP",
            "properties": {
              "priority": 110,
              "access": "Allow",
              "direction": "Inbound",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "80",
              "sourceAddressPrefix": "*",
              "destinationAddressPrefix": "*"
            }
          },
          {
            "name": "Allow-HTTPS",
            "properties": {
              "priority": 120,
              "access": "Allow",
              "direction": "Inbound",
              "protocol": "Tcp",
              "sourcePortRange": "*",
              "destinationPortRange": "443",
              "sourceAddressPrefix": "*",
              "destinationAddressPrefix": "*"
            }
          }
        ]
      }
    },

    // VNET
    {
      "type": "Microsoft.Network/virtualNetworks",
      "apiVersion": "2021-05-01",
      "name": "[parameters('vnetName')]",
      "location": "[parameters('location')]",
      "dependsOn": ["nsg1"],
      "properties": {
        "addressSpace": {
          "addressPrefixes": ["10.0.0.0/16"]
        },
        "subnets": [
          {
            "name": "subnet1",
            "properties": {
              "addressPrefix": "[parameters('subnet1Prefix')]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups','nsg1')]"
              }
            }
          },
          {
            "name": "subnet2",
            "properties": {
              "addressPrefix": "[parameters('subnet2Prefix')]",
              "networkSecurityGroup": {
                "id": "[resourceId('Microsoft.Network/networkSecurityGroups','nsg1')]"
              }
            }
          }
        ]
      }
    },

    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2021-05-01",
      "name": "pip1",
      "location": "[parameters('location')]",
      "sku": { "name": "Basic" },
      "properties": {
        "publicIPAllocationMethod": "Dynamic",
        "dnsSettings": {
          "domainNameLabel": "[concat('vm1dns', uniqueString(resourceGroup().id))]"
        }
      }
    },
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2021-05-01",
      "name": "pip2",
      "location": "[parameters('location')]",
      "sku": { "name": "Basic" },
      "properties": {
        "publicIPAllocationMethod": "Dynamic",
        "dnsSettings": {
          "domainNameLabel": "[concat('vm2dns', uniqueString(resourceGroup().id))]"
        }
      }
},
    
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2021-05-01",
      "name": "nic1",
      "location": "[parameters('location')]",
      "dependsOn": ["pip1", "[parameters('vnetName')]"],
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig1",
            "properties": {
              "subnet": {
                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', parameters('vnetName'), 'subnet1')]"
              },
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses','pip1')]"
              }
            }
          }
        ]
      }
    },
    {
      "type": "Microsoft.Network/networkInterfaces",
      "apiVersion": "2021-05-01",
      "name": "nic2",
      "location": "[parameters('location')]",
      "dependsOn": ["pip2", "[parameters('vnetName')]"],
      "properties": {
        "ipConfigurations": [
          {
            "name": "ipconfig2",
            "properties": {
              "subnet": {
                "id": "[resourceId('Microsoft.Network/virtualNetworks/subnets', parameters('vnetName'), 'subnet2')]"
              },
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses','pip2')]"
              }
            }
          }
        ]
      }
    },

    // VM1
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2021-07-01",
      "name": "[parameters('vm1Name')]",
      "location": "[parameters('location')]",
      "dependsOn": ["nic1"],
      "properties": {
        "hardwareProfile": {
          "vmSize": "Standard_B1s"
        },
        "osProfile": {
          "computerName": "[parameters('vm1Name')]",
          "adminUsername": "[parameters('adminUsername')]",
          "adminPassword": "[parameters('adminPassword')]",
          "windowsConfiguration": {
                    "enableAutomaticUpdates": true
                  }
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "MicrosoftWindowsServer",
            "offer": "WindowsServer",
            "sku": "2022-Datacenter",
            "version": "latest"
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces','nic1')]"
            }
          ]
        }
      }
    },

    // VM2
    {
      "type": "Microsoft.Compute/virtualMachines",
      "apiVersion": "2021-07-01",
      "name": "[parameters('vm2Name')]",
      "location": "[parameters('location')]",
      "dependsOn": ["nic2"],
      "properties": {
        "hardwareProfile": {
          "vmSize": "Standard_B1s"
        },
        "osProfile": {
          "computerName": "[parameters('vm2Name')]",
          "adminUsername": "[parameters('adminUsername')]",
          "adminPassword": "[parameters('adminPassword')]",
          "windowsConfiguration": {
          "enableAutomaticUpdates": true
        }
        },
        "storageProfile": {
          "imageReference": {
            "publisher": "MicrosoftWindowsServer",
            "offer": "WindowsServer",
            "sku": "2022-Datacenter",
            "version": "latest"
          }
        },
        "networkProfile": {
          "networkInterfaces": [
            {
              "id": "[resourceId('Microsoft.Network/networkInterfaces','nic2')]"
            }
          ]
        }
      }
    },

    // Nested Template Call
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2021-04-01",
      "name": "rbacDeployment",
      "dependsOn": [
        "[parameters('vm1Name')]",
        "[parameters('vm2Name')]"
      ],
      "properties": {
        "mode": "Incremental",
        "templateLink": {
          "uri": "[parameters('nestedTemplateUrl')]"
        },
        "parameters": {
          "principalId": {
            "value": "[parameters('principalId')]"
          }
        }
      }
    }
  ],
  "outputs": {
  "vm1PublicDNS": {
    "type": "string",
    "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses','pip1')).dnsSettings.fqdn]"
  },
  "vm2PublicDNS": {
    "type": "string",
    "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses','pip2')).dnsSettings.fqdn]"
  },
  "adminUsername": {
    "type": "string",
    "value": "[parameters('adminUsername')]"
  },
  "adminPasswordOutput": {
  "type": "string",
  "value": "[parameters('adminPassword')]"
  },  
  "rdpCommandVM1": {
  "type": "string",
  "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses','pip1')).ipAddress]"
},
  "rdpCommandVM2": {
  "type": "string",
  "value": "[reference(resourceId('Microsoft.Network/publicIPAddresses','pip2')).ipAddress]"
}
}
}
